# Set default behavior to treat files as text
* text=auto

# Source code files
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.html text eol=lf
*.md text eol=lf

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# YAML files
*.yml text eol=lf
*.yaml text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.svg binary
*.ico binary
*.pdf binary

# Build outputs
dist/ -export-ignore
build/ -export-ignore
node_modules/ -export-ignore
